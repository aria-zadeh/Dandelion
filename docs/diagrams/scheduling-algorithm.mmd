flowchart TD
    INPUT["📥 Inputs<br/>Task: title, dueDate, estimatedMinutes<br/>User: availability grid, energy peaks<br/>History: scheduling_signals table"]

    GEN["1️⃣ Generate Candidates<br/>Every 30-min window in next 7 days"]
    FILTER["2️⃣ Filter<br/>Remove busy blocks<br/>Remove quiet hours (11pm–8am)"]
    SCORE["3️⃣ Score Each Slot<br/>Base score<br/>+ Energy peak bonus<br/>+ Proximity-to-deadline penalty<br/>+ Historical completion rate at hour<br/>+ Break buffer penalty (>90min consecutive)"]
    SELECT["4️⃣ Select Top Slot"]
    WRITE["5️⃣ Write to Calendar<br/>proposedTime → Zustand + Supabase"]
    NOTIFY["📬 Schedule Notification<br/>15 min before proposed time"]

    COMPLETE["✅ Task Completed"]
    SIGNAL["6️⃣ Write SchedulingSignal<br/>hour, dayOfWeek, outcome"]
    LEARN["7️⃣ Future Runs Read Signals<br/>Improve energy window accuracy"]

    INPUT --> GEN --> FILTER --> SCORE --> SELECT --> WRITE --> NOTIFY
    COMPLETE --> SIGNAL --> LEARN
    LEARN -.->|"feeds back"| SCORE

    style LEARN fill:#E8F9F0,stroke:#3ECF8E,stroke-width:2px
    style SIGNAL fill:#E8F9F0,stroke:#3ECF8E,stroke-width:2px
